{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "declaration": false,
    "sourceMap": true,
    "lib": ["ES2022", "DOM"],
    "types": ["chrome-types"]
  },
  "include": [
    "background/**/*.ts",
    "popup/**/*.ts",
    "content/**/*.ts",
    "sidepanel/**/*.ts",
    "shared/**/*.ts"
  ]
}
