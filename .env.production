# ─── 艾琳 (Ailin) 生产环境配置模板 ────────────────────
# 部署时复制为 .env 并填入真实值
# ⚠️ .env 不提交 git（已在 .gitignore 中）
# ─────────────────────────────────────────────────────

NODE_ENV=production
PORT=8080

# ─── Supabase 数据库 ──────────────────────────────────
# 从 Supabase Dashboard → Project Settings → API 获取
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── LLM（公司内网 API，服务器可直接访问） ────────────
LLM_PROVIDER=volcengine
LLM_API_KEY=your-llm-api-key
LLM_BASE_URL=http://your-llm-api-base-url/api/v1
LLM_MODEL=your-model-name

# ─── STT 语音识别（MVP 用 mock） ─────────────────────
STT_PROVIDER=mock
# STT_API_KEY=
# STT_API_SECRET=

# ─── SMS 短信（MVP 用 mock） ─────────────────────────
SMS_PROVIDER=mock
# SMS_API_KEY=
# SMS_API_SECRET=

# ─── JWT ─────────────────────────────────────────────
# ⚠️ 必须修改！生成命令：openssl rand -hex 32
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHARACTER_SECRET_STRING
JWT_EXPIRES_IN=7200
JWT_REFRESH_EXPIRES_IN=604800

# ─── 文件上传 ────────────────────────────────────────
UPLOAD_MAX_SIZE_MB=10
UPLOAD_DIR=/app/uploads

# ─── 日志目录 ──────────────────────────────────────
LOG_DIR=/data/logs/ailin-server

# ─── CORS ────────────────────────────────────────────
# 填写服务器实际 IP 或域名（多个用逗号分隔）
# Chrome 插件的 chrome-extension:// 来源在代码中已单独处理
CORS_ORIGIN=http://YOUR_SERVER_IP

# ─── 智联招聘 API ────────────────────────────────────
ZHAOPIN_API_BASE=https://cgate.zhaopin.com
