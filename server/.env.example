# ─── 服务器 ───────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── 数据库（Supabase） ──────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── LLM（多模型支持） ──────────────────────────
# 可选值: deepseek | qwen | moonshot | mock
LLM_PROVIDER=mock
LLM_API_KEY=your-api-key
# LLM_BASE_URL=          # 留空使用默认地址
# LLM_MODEL=             # 留空使用默认模型

# ─── STT（语音转文字） ──────────────────────────
# 可选值: xfyun | aliyun | mock
STT_PROVIDER=mock
# STT_API_KEY=
# STT_API_SECRET=

# ─── SMS（短信验证码） ──────────────────────────
# 可选值: aliyun | mock
SMS_PROVIDER=mock
# SMS_API_KEY=
# SMS_API_SECRET=

# ─── JWT ─────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-string
JWT_EXPIRES_IN=7200
JWT_REFRESH_EXPIRES_IN=604800

# ─── 文件上传 ───────────────────────────────────
UPLOAD_MAX_SIZE_MB=10
UPLOAD_DIR=./uploads

# ─── CORS ────────────────────────────────────────
CORS_ORIGIN=*

# ─── 智联招聘 API ───────────────────────────────
ZHAOPIN_API_BASE=https://cgate.zhaopin.com
