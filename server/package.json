{
  "name": "ailin-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/server/src/index.js",
    "typecheck": "tsc --noEmit",
    "test:batch": "tsx scripts/batch-test.ts",
    "test:batch:quick": "tsx scripts/batch-test.ts --limit 1",
    "test:batch:truthful": "tsx scripts/batch-test.ts --style truthful"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@supabase/supabase-js": "^2.98.0",
    "dotenv": "^16.4.0",
    "hono": "^4.7.0",
    "jose": "^6.1.3",
    "openai": "^6.25.0",
    "pdf-parse": "^1.1.1",
    "uuid": "^11.1.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/uuid": "^10.0.0",
    "tsc-alias": "^1.8.0",
    "tsx": "^4.19.0",
    "typescript": "~5.8.2"
  }
}
